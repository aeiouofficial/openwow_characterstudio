{
  "name": "@aeiou/character-studio",
  "version": "3.2.0",
  "description": "CHARACTER STUDIO - made by AEiOU \u2014 offline WebGL2 character customization studio with per-geoset texture alignment/warp, eye-region correction, GLB/texture bundle auto-wiring, reusable asset-source presets, content packs, GLB export, MCP, and headless mode",
  "type": "module",
  "main": "./src/engine/index.ts",
  "exports": {
    ".": "./src/engine/index.ts",
    "./studio": "./src/engine/CharacterStudioEngine.ts",
    "./io": "./src/io/GltfRuntime.ts"
  },
  "scripts": {
    "start": "node server.mjs",
    "test": "node --test qa/unit.test.mjs",
    "qa:smoke": "node qa/browser-smoke.mjs",
    "qa:visual": "node qa/visual-regression.mjs",
    "qa:mcp": "node qa/mcp-test.mjs",
    "mcp": "node qa/mcp-server.mjs"
  },
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "files": [
    "server.mjs",
    "START_CHARACTER_STUDIO.cmd",
    "src",
    "demo",
    "docs",
    "qa",
    "README.md",
    "CHANGELOG.md"
  ],
  "license": "MIT"
}
